{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"color": "#D4AF37",
					"name": "Gold",
					"slug": "gold"
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#1A1A1A",
					"name": "Black",
					"slug": "black"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Manrope, sans-serif",
					"name": "Manrope",
					"slug": "body"
				},
				{
					"fontFamily": "'Noto Serif', serif",
					"name": "Noto Serif",
					"slug": "headings"
				}
			],
			"fontSizes": [
				{
					"size": "18px",
					"name": "Paragraph",
					"slug": "base"
				},
				{
					"size": "48px",
					"name": "H2",
					"slug": "h2"
				},
				{
					"size": "128px",
					"name": "H1",
					"slug": "h1"
				},
				{
					"size": "30px",
					"name": "H3",
					"slug": "h3"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"padding": true,
			"margin": true
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "18px",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--black)"
		},
		"spacing": {
			"padding": {
				"top": "60px",
				"bottom": "60px",
				"left": "60px",
				"right": "60px"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontSize": "128px",
					"fontWeight": "400",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontSize": "48px",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontSize": "30px",
					"fontWeight": "400",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontWeight": "400"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontWeight": "400"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontWeight": "400"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--black)"
				},
				"typography": {
					"textDecoration": "none"
				}
			}
		}
	}
}